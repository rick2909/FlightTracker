@namespace FlightTracker.Web.Pages
@page "/"

<div class="landing-page">
    <section class="hero">
        <div class="hero__background">
            <div class="hero__content">
                <div class="hero__text">
                    <h1 class="hero__title">
                        Track Your <span class="hero__accent">Aviation Journey</span>
                    </h1>
                    <p class="hero__subtitle">
                        The modern flight tracking platform for aviation enthusiasts.
                        Record your flights, explore statistics, and showcase your travel passport.
                    </p>
                    <div class="hero__actions">
                        <a href="/register" class="btn btn--primary btn--large">
                            <i class="material-icons">flight_takeoff</i>
                            Start Tracking
                        </a>
                        <a href="/login" class="btn btn--secondary btn--large">
                            <i class="material-icons">login</i>
                            Sign In
                        </a>
                    </div>
                </div>
                <div class="hero__visual">
                    <div class="hero__plane">
                        <i class="material-icons">flight</i>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="stats-preview">
        <div class="stats-preview__content">
            <h2 class="stats-preview__title">Join Thousands of Aviation Enthusiasts</h2>
            <div class="stats-preview__grid">
                <div class="stat-card">
                    <div class="stat-card__icon">
                        <i class="material-icons">flight_takeoff</i>
                    </div>
                    <div class="stat-card__value">125,847</div>
                    <div class="stat-card__label">Flights Tracked</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card__icon">
                        <i class="material-icons">public</i>
                    </div>
                    <div class="stat-card__value">2,450</div>
                    <div class="stat-card__label">Airports Visited</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card__icon">
                        <i class="material-icons">people</i>
                    </div>
                    <div class="stat-card__value">8,320</div>
                    <div class="stat-card__label">Active Users</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card__icon">
                        <i class="material-icons">eco</i>
                    </div>
                    <div class="stat-card__value">45.2M</div>
                    <div class="stat-card__label">Miles Tracked</div>
                </div>
            </div>
        </div>
    </section>

    <section class="features">
        <div class="features__content">
            <h2 class="features__title">Everything You Need to Track Your Flights</h2>
            <div class="features__grid">
                <div class="feature-card">
                    <div class="feature-card__icon">
                        <i class="material-icons">map</i>
                    </div>
                    <h3 class="feature-card__title">Interactive Flight Maps</h3>
                    <p class="feature-card__description">
                        Visualize your routes on beautiful interactive maps with real-time flight data and great circle routes.
                    </p>
                </div>
                <div class="feature-card">
                    <div class="feature-card__icon">
                        <i class="material-icons">analytics</i>
                    </div>
                    <h3 class="feature-card__title">Detailed Statistics</h3>
                    <p class="feature-card__description">
                        Track miles flown, airports visited, favorite airlines, and detailed analytics of your aviation journey.
                    </p>
                </div>
                <div class="feature-card">
                    <div class="feature-card__icon">
                        <i class="material-icons">badge</i>
                    </div>
                    <h3 class="feature-card__title">Digital Passport</h3>
                    <p class="feature-card__description">
                        Create a beautiful digital aviation passport showcasing your travels, achievements, and milestones.
                    </p>
                </div>
                <div class="feature-card">
                    <div class="feature-card__icon">
                        <i class="material-icons">schedule</i>
                    </div>
                    <h3 class="feature-card__title">Flight Status Tracking</h3>
                    <p class="feature-card__description">
                        Real-time status updates for your upcoming flights with pre-flight, at-airport, and post-flight workflows.
                    </p>
                </div>
                <div class="feature-card">
                    <div class="feature-card__icon">
                        <i class="material-icons">eco</i>
                    </div>
                    <h3 class="feature-card__title">Environmental Impact</h3>
                    <p class="feature-card__description">
                        Monitor your aviation carbon footprint with detailed emission calculations and environmental insights.
                    </p>
                </div>
                <div class="feature-card">
                    <div class="feature-card__icon">
                        <i class="material-icons">devices</i>
                    </div>
                    <h3 class="feature-card__title">Multi-Platform</h3>
                    <p class="feature-card__description">
                        Access your flight data anywhere with our responsive web interface, designed for desktop and mobile.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="cta">
        <div class="cta__content">
            <h2 class="cta__title">Ready to Start Your Journey?</h2>
            <p class="cta__subtitle">Join thousands of aviation enthusiasts tracking their flights</p>
            <div class="cta__actions">
                <a href="/register" class="btn btn--primary btn--large">
                    <i class="material-icons">flight_takeoff</i>
                    Create Free Account
                </a>
            </div>
        </div>
    </section>
</div>
