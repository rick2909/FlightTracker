@page "/Passport/Details"
@page "/Passport/{Id:int}/Details"
@attribute [Authorize]

@if (Model is null)
{
    <div class="rz-p-4">Loading passport details...</div>
}
else
{
    <div class="passport-section">
        <div class="rz-card">
            <div class="rz-card-header">
                <h3>Detailed Analysis for @Model.UserName</h3>
            </div>
            <div class="rz-card-body">
                <p style="color:var(--rz-text-color);font-size:1rem;">Comprehensive breakdown of your aviation journey</p>
            </div>
        </div>
    </div>

    <div class="passport-section">
        <div class="rz-card">
            <div class="rz-card-header">
                <h3><span class="material-icons" aria-hidden="true">history</span>Flight History (@(Model.UserFlights?.Count() ?? 0) flights)</h3>
            </div>
            <div class="rz-card-body">
                @if (Model.UserFlights?.Any() == true)
                {
                    <FlightTracker.Web.Components.UserFlightsList Flights="Model.UserFlights" DateFormat="Model.DateFormat" TimeFormat="Model.TimeFormat" />
                }
                else
                {
                    <div class="text-center py-5">
                        <span class="material-icons" style="font-size:4rem;color:var(--rz-text-disabled-color);margin-bottom:1rem;">flight</span>
                        <h4>No flights recorded</h4>
                    </div>
                }
            </div>
        </div>
    </div>
}