@page "/UserFlights"
@page "/UserFlights/{UserId:int}"
@attribute [Authorize]

<div class="remove__header"></div>

<div class="row">
    <div class="col-12">
        <div class="ft-toolbar">
            <h1 class="d-flex align-items-center">@Title</h1>
            <div class="ft-toolbar__actions">
                <FlightTracker.Web.Components.Flights.AddFlightLauncher />
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Flight History (@Flights.Count flights)</h5>
            </div>
            <div class="card-body">
                @if (Flights.Any())
                {
                    <FlightTracker.Web.Components.UserFlightsList Flights="Flights" DateFormat="DateFormat" TimeFormat="TimeFormat" />
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fas fa-plane fa-3x text-muted mb-3"></i>
                        <h4>No flights recorded</h4>
                        <p class="text-muted">Start tracking your aviation journey by adding your first flight!</p>
                        <FlightTracker.Web.Components.Flights.AddFlightLauncher />
                    </div>
                }
            </div>
        </div>
    </div>
</div>
