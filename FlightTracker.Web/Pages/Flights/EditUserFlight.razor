@namespace FlightTracker.Web.Pages
@page "/UserFlights/Edit/{Id:int}"
@attribute [Authorize]

<div class="container py-4">
    <div class="row g-4">
        <div class="col-12 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Edit Flight @FlightNumber</h5>
                    <span class="badge bg-secondary">@RouteSummary</span>
                </div>
                <div class="card-body">
                    <FlightTracker.Web.Components.Flights.EditUserFlightForm UserFlightId="Id" />
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-4">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h6 class="mb-0">Summary</h6>
                </div>
                <div class="card-body">
                    <div class="mb-2"><strong>@DepartureCode</strong> → <strong>@ArrivalCode</strong></div>
                    <div class="text-muted">@TimeSummary</div>
                </div>
            </div>
        </div>
    </div>
</div>
